# Complex accessors: real, imag, conj, angle/arg
real(3 + 4i)
=> 3
imag(3 + 4i)
=> 4
conj(3 + 4i)
=> 3-4i
angle(1i)
=> 1.5708
arg(-1)
=> 3.14159
real(5)
=> 5
imag(5)
=> 0
conj(5)
=> 5
conj([1 + 2i, 3 - 1i])
=> [1-2i, 3+1i]
real([1 + 2i, 3, 4 - 1i])
=> [1, 3, 4]
imag([1, 2, 3])
=> [0, 0, 0]
let z = 2 + 3i; conj(z) * z
=> 13+0i
real(exp(1i)) == cos(1)
=> true
round(imag(log(-1)) * 100)
=> 314
conj(1 + 1i) + (1 + 1i)
=> 2+0i
