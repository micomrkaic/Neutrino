# Floating-point predicates (results are logical, so portable as goldens)
isnan(0/0)
=> true
isinf(1/0)
=> true
isinf(-1/0)
=> true
isnan(1/0)
=> false
isfinite(1.5)
=> true
isnan(5)
=> false
isfinite(5)
=> true
isinf(5)
=> false
isnan([1, 0/0, 3])
=> [false, true, false]
isinf([1.0, 1/0, 0/0])
=> [false, true, false]
isfinite([1, 1/0, 2])
=> [true, false, true]
any(isnan([1, 2, 0/0]))
=> true
all(isfinite([1, 2, 3]))
=> true
isnan(2 + (0/0) * 1i)
=> true
isfinite(3 + 4i)
=> true
