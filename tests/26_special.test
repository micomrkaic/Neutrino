# Special functions. Spot values cross-checked against SciPy; identities where cleaner.
erf(0)
=> 0
format(8); erf(0.5)
=> 0.52049988
format(8); erfc(1.2)
=> 0.089686022
# erf + erfc == 1
abs(erf(0.7) + erfc(0.7) - 1) < 1e-15
=> true
# beta via gamma identity: beta(2,3) = 1/12
format(8); beta(2, 3)
=> 0.083333333
abs(beta(4, 5) - gamma(4) * gamma(5) / gamma(9)) < 1e-15
=> true
format(8); lbeta(5, 7)
=> -7.7450028
# gammainc(x, 1) = 1 - exp(-x)
abs(gammainc(1.7, 1) - (1 - exp(-1.7))) < 1e-14
=> true
format(8); gammainc(2, 3)
=> 0.32332358
# chi-square CDF with 2 dof at x=3: gammainc(1.5, 1)
format(8); gammainc(1.5, 1)
=> 0.77686984
format(8); betainc(0.3, 2, 5)
=> 0.57982500
# betainc symmetry: I_x(a,b) = 1 - I_{1-x}(b,a)
abs(betainc(0.3, 2, 5) - (1 - betainc(0.7, 5, 2))) < 1e-14
=> true
betainc(0, 2, 3)
=> 0
betainc(1, 2, 3)
=> 1
# norminv: quantile and round-trip through the CDF (0.5*erfc(-x/sqrt(2)))
format(8); norminv(0.975)
=> 1.9599640
norminv(0.5)
=> 0
abs(norminv(0.5 * erfc(-1.3 / sqrt(2))) - 1.3) < 1e-12
=> true
# digamma: psi(1) = -euler; recurrence psi(x+1) = psi(x) + 1/x
format(8); digamma(1)
=> -0.57721566
abs(digamma(5.3) - (digamma(4.3) + 1/4.3)) < 1e-13
=> true
format(8); digamma(-1.5)
=> 0.70315664
# Bessel: J0 root region and Y0 spot; besselj(0,0)=1
besselj(0, 0)
=> 1
format(8); besselj(0, 2.4)
=> 0.0025076833
format(8); bessely(0, 1)
=> 0.088256964
# elementwise over arrays
format(8); erf([0, 0.5])
=> [0.0000000, 0.52049988]
format(8); gammainc([1, 2], 1)
=> [0.63212056, 0.86466472]
# domain errors
gammainc(-1, 2)
=> !requires x >= 0
betainc(1.5, 2, 3)
=> !0 <= x <= 1
bessely(0, -1)
=> !x > 0
digamma(0)
=> !pole
norminv(2)
=> !0 <= p <= 1
# kron: shapes, scalars, complex
kron([1, 2; 3, 4], eye(2))
=> [1, 0, 2, 0; 0, 1, 0, 2; 3, 0, 4, 0; 0, 3, 0, 4]
kron([1, 2], [1; 1])
=> [1, 2; 1, 2]
kron(2, [1, 2; 3, 4])
=> [2, 4; 6, 8]
kron([1i, 0; 0, 1], [1, 1])
=> [1i, 1i, 0+0i, 0+0i; 0+0i, 0+0i, 1+0i, 1+0i]
