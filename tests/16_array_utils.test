# Array utilities: shape, find, sort, cumulative, diff, tiling, flips, binary min/max
length([1, 2, 3, 4, 5])
=> 5
length([1, 2, 3; 4, 5, 6])
=> 3
numel([1, 2, 3; 4, 5, 6])
=> 6
find([0, 3, 0, 5, 0])
=> [2, 4]
find([1, 2, 3, 4] > 2)
=> [3, 4]
let a = [3, 7, 2, 9, 1, 6]; a[find(a > 5)]
=> [7, 9, 6]
sort([3, 1, 4, 1, 5, 9, 2, 6])
=> [1, 1, 2, 3, 4, 5, 6, 9]
sort([3, 1; 5, 1; 4, 9])
=> [3, 1; 4, 1; 5, 9]
cumsum([1, 2, 3, 4])
=> [1, 3, 6, 10]
cumprod([1, 2, 3, 4])
=> [1, 2, 6, 24]
cumsum([1, 2; 3, 4])
=> [1, 2; 4, 6]
diff([1, 4, 9, 16, 25])
=> [3, 5, 7, 9]
diff([1, 2; 3, 5; 6, 10])
=> [2, 3; 3, 5]
repmat([1, 2], 2, 3)
=> [1, 2, 1, 2, 1, 2; 1, 2, 1, 2, 1, 2]
repmat(5, 2, 2)
=> [5, 5; 5, 5]
flipud([1, 2; 3, 4; 5, 6])
=> [5, 6; 3, 4; 1, 2]
fliplr([1, 2, 3; 4, 5, 6])
=> [3, 2, 1; 6, 5, 4]
min([3, 1, 4], [2, 2, 2])
=> [2, 1, 2]
max([3, 1, 4], 2)
=> [3, 2, 4]
min([5, 2, 8, 1])
=> 1
max([5, 2, 8, 1])
=> 8
sum(cumsum([1, 1, 1, 1]))
=> 10
sort([1i, 2i])
=> !undefined for complex
min([1i], [2i])
=> !undefined
# where: index form and elementwise select
where([0, 5, 0, 9])
=> [2, 4]
where([1, 0, 1, 0], [10, 20, 30, 40], [-1, -2, -3, -4])
=> [10, -2, 30, -4]
let x = [-3, 2, -1, 4]; where(x > 0, x, 0)
=> [0, 2, 0, 4]
where([1, 0; 0, 1], 9, 0)
=> [9, 0; 0, 9]
where(true, 100, 200)
=> 100
where([1, 0], [1, 2, 3], 0)
=> !shape mismatch
where([1, 0], 1, 2, 3)
=> !wrong number of arguments
