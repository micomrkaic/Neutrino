# Axis-aware reductions: dim 1 = down columns (-> row), dim 2 = across rows (-> column)
sum([1, 2, 3; 4, 5, 6], 1)
=> [5, 7, 9]
sum([1, 2, 3; 4, 5, 6], 2)
=> [6; 15]
sum([1, 2, 3; 4, 5, 6])
=> 21
prod([1, 2; 3, 4], 1)
=> [3, 8]
prod([1, 2; 3, 4], 2)
=> [2; 12]
mean([2, 4; 6, 8], 1)
=> [4, 6]
mean([2, 4; 6, 8], 2)
=> [3; 7]
max([1, 9; 7, 3], [], 1)
=> [7, 9]
max([1, 9; 7, 3], [], 2)
=> [9; 7]
min([1, 9; 7, 3], [], 1)
=> [1, 3]
min([1, 9; 7, 3], [], 2)
=> [1; 3]
any([0, 1; 0, 0], 1)
=> [false, true]
all([1, 1; 1, 0], 2)
=> [true; false]
# elementwise min/max (2-arg) still works
min([3, 1, 4], [2, 2, 2])
=> [2, 1, 2]
# bad dim and bad 3-arg shape
sum([1, 2; 3, 4], 3)
=> !dim must be 1
max([1, 2], 5, 1)
=> !3-argument form
