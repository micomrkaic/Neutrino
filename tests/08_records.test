# Records
let r = {a = 1, b = 2}; r.a
=> 1
let r = {a = 1, b = 2}; r.b
=> 2
let r = {x = 10, y = 20}; r.x + r.y
=> 30
let r = {f = fn n -> n * 2}; r.f(21)
=> 42
let r = {data = 1:5}; r.data[3]
=> 3
let r = {p = {q = 7}}; r.p.q
=> 7
{name = "neutrino", n = 3}.n
=> 3
let pt = {x = 3, y = 4}; sqrt(pt.x .^ 2 + pt.y .^ 2)
=> 5
