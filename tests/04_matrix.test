# Constructors and linear algebra
eye(2)
=> [1, 0; 0, 1]
zeros(2, 2)
=> [0, 0; 0, 0]
ones(2, 3)
=> [1, 1, 1; 1, 1, 1]
trace([1, 2; 3, 4])
=> 5
det([1, 2; 3, 4])
=> -2
det([2, 0; 0, 3])
=> 6
inv([2, 0; 0, 4])
=> [0.5, 0; 0, 0.25]
[2, 0; 0, 4] \ [2; 4]
=> [1; 1]
diag([1, 2, 3])
=> [1, 0, 0; 0, 2, 0; 0, 0, 3]
diag([1, 2; 3, 4])
=> [1; 4]
dot([1, 2, 3], [4, 5, 6])
=> 32
kron(eye(2), [1, 2; 3, 4])
=> [1, 2, 0, 0; 3, 4, 0, 0; 0, 0, 1, 2; 0, 0, 3, 4]
reshape(1:6, 2, 3)
=> [1, 2, 3; 4, 5, 6]
linspace(0, 1, 5)
=> [0, 0.25, 0.5, 0.75, 1]
norm([3, 4])
=> 5
norm([1, 2, 3], 1)
=> 6
