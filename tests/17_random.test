# RNG: determinism, shapes, ranges (invariant-based — no float snapshots)
# same seed reproduces the same draws
rng(1); let a = rand(1, 4); rng(1); let b = rand(1, 4); a - b
=> [0, 0, 0, 0]
rng(3); let x = randn(2, 3); rng(3); let y = randn(2, 3); x - y
=> [0, 0, 0; 0, 0, 0]
rng(9); let a = sum(rand(1, 50)); rng(9); let b = sum(rand(1, 50)); a - b
=> 0
# shapes
size(rand(3, 5))
=> [3, 5]
size(randn(4))
=> [4, 4]
numel(randi(10, 3, 4))
=> 12
# uniform draws lie in [0, 1)
all(rand(1, 300) >= 0)
=> true
all(rand(1, 300) < 1)
=> true
# randi stays within bounds
rng(2); let r = randi(6, 1, 500); all(r >= 1)
=> true
rng(2); let r = randi(6, 1, 500); all(r <= 6)
=> true
rng(9); randi([7, 7], 1, 4)
=> [7, 7, 7, 7]
# errors
randi([5, 2], 1, 3)
=> !empty range
rand(-1)
=> !negative
