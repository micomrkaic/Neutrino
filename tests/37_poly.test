# packages/poly.nu — polynomials (NumPy-cross-checked; see file header)
load("packages/poly.nu"); polyval([2, -3, 1], 4)
=> 21
load("packages/poly.nu"); polyval([1, 0, -2], [1, 2, 3])
=> [-1, 2, 7]
load("packages/poly.nu"); companion([1, -6, 11, -6])
=> [6, -11, 6; 1, 0, 0; 0, 1, 0]
load("packages/poly.nu"); format(6); sort(real(roots([1, -6, 11, -6])))'
=> [1.00000, 2.00000, 3.00000]
load("packages/poly.nu"); roots([1, 0, 1])'
=> [1i, -1i]
# non-monic normalizes
load("packages/poly.nu"); format(6); sort(real(roots([2, -12, 22, -12])))'
=> [1.00000, 2.00000, 3.00000]
# polyfit: NumPy-checked least squares
load("packages/poly.nu"); format(8); abs(polyfit([0, 1, 2, 3, 4], [1.1, 2.9, 9.2, 19.1, 32.8], 2) - [1.95714286, 0.13142857, 1.01428571]) < 1e-7
=> [true, true, true]
# exact recovery through exact data
load("packages/poly.nu"); format(6); polyfit([1, 2, 3], [polyval([2, -1, 3], 1), polyval([2, -1, 3], 2), polyval([2, -1, 3], 3)], 2)
=> [2.00000, -1.00000, 3.00000]
# calculus identities
load("packages/poly.nu"); polyder([1, -6, 11, -6])
=> [3, -12, 11]
load("packages/poly.nu"); polyint(polyder([1, -6, 11, -6]), -6)
=> [1, -6, 11, -6]
load("packages/poly.nu"); polyder([7])
=> [0]
# algebra: conv multiplies, roots survive
load("packages/poly.nu"); conv([1, -1], [1, -2])
=> [1, -3, 2]
load("packages/poly.nu"); format(6); sort(real(roots(conv([1, -1], conv([1, -2], [1, -3])))))'
=> [1.00000, 2.00000, 3.00000]
# validation
load("packages/poly.nu"); roots([5])
=> !degree >= 1
load("packages/poly.nu"); polyfit([1, 2], [1, 2, 3], 1)
=> !same length
load("packages/poly.nu"); polyfit([1, 2], [1, 2], 5)
=> !need at least 6 points
