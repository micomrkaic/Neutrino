# packages/finance.nu — HP-12C functionality (independently cross-checked)
# TVM
load("packages/finance.nu"); format(6); pmt(360, 0.005, 250000, 0)
=> -1498.88
load("packages/finance.nu"); abs(pmt(360, 0.005, 250000, 0) - (-1498.876313)) < 1e-5
=> true
load("packages/finance.nu"); abs(fv(120, 0.004, 0, -200) - 30726.391802) < 1e-5
=> true
load("packages/finance.nu"); abs(pv(360, 0.005, -1498.876313, 0) - 250000) < 1e-3
=> true
load("packages/finance.nu"); abs(nper(0.005, 250000, -1498.876313, 0) - 360) < 1e-6
=> true
load("packages/finance.nu"); abs(rate(360, 250000, -1498.876313, 0) - 0.005) < 1e-9
=> true
load("packages/finance.nu"); abs(rate(10, 1000, -150, 0) - 0.08144170) < 1e-7
=> true
load("packages/finance.nu"); pmt(0, 0.01, 100, 0)
=> !n must be positive
# cash flows
load("packages/finance.nu"); abs(npv(0.10, [-1000, 300, 420, 680]) - 130.728775) < 1e-5
=> true
load("packages/finance.nu"); abs(irr([-1000, 300, 420, 680]) - 0.16340560) < 1e-7
=> true
load("packages/finance.nu"); abs(npv(irr([-1000, 300, 420, 680]), [-1000, 300, 420, 680])) < 1e-8
=> true
load("packages/finance.nu"); irr([-100, -50])
=> !must change sign
# bonds
load("packages/finance.nu"); abs(bond_price(100, 0.08, 0.06, 10, 1) - 114.720174) < 1e-5
=> true
load("packages/finance.nu"); abs(bond_ytm(114.720174, 100, 0.08, 10, 1) - 0.06) < 1e-8
=> true
load("packages/finance.nu"); abs(bond_duration(100, 0.08, 0.06, 10, 1) - 7.445020) < 1e-5
=> true
load("packages/finance.nu"); abs(bond_mduration(100, 0.08, 0.06, 10, 1) - 7.023604) < 1e-5
=> true
# par bond identity: coupon at ytm prices at face
load("packages/finance.nu"); abs(bond_price(100, 0.07, 0.07, 30, 2) - 100) < 1e-9
=> true
# amortization: schedule sums and terminal balance
load("packages/finance.nu"); let s = amort(1000, 0.01, 3); abs(s.payment[1] - 340.022111) < 1e-5
=> true
load("packages/finance.nu"); let s = amort(1000, 0.01, 3); abs(sum(s.principal) - 1000) < 1e-8
=> true
load("packages/finance.nu"); let s = amort(1000, 0.01, 3); abs(s.balance[3]) < 1e-9
=> true
load("packages/finance.nu"); let s = amort(360000, 0.005, 360); abs(s.balance[360]) < 1e-6
=> true
# dates: HP-12C arithmetic (python-datetime-checked)
load("packages/finance.nu"); days(2024, 2, 28, 2024, 3, 1)
=> 2
load("packages/finance.nu"); days(2026, 1, 1, 2026, 7, 9)
=> 189
load("packages/finance.nu"); dow(2026, 7, 9)
=> 4
load("packages/finance.nu"); dateadd(2024, 2, 28, 2)
=> {y = 2024, m = 3, d = 1}
load("packages/finance.nu"); dateadd(2024, 12, 31, 1)
=> {y = 2025, m = 1, d = 1}
load("packages/finance.nu"); days360(2024, 1, 31, 2024, 7, 31)
=> 180
load("packages/finance.nu"); days(2024, 2, 28, 2024, 13, 1)
=> !month must be 1..12
# roundtrip: datestr inverts datenum across a leap boundary
load("packages/finance.nu"); let j = datenum(2024, 2, 29); let d = datestr(j); [d.y, d.m, d.d]
=> [2024, 2, 29]
