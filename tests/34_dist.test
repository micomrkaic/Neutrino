# packages/dist.nu — cross-checked against SciPy (see file header)
load("packages/dist.nu"); abs(norm.cdf(1.96, 0, 1) - 0.97500210) < 1e-7
=> true
load("packages/dist.nu"); abs(norm.inv(0.975, 0, 1) - 1.9599640) < 1e-6
=> true
load("packages/dist.nu"); abs(norm.pdf(1.5, 0, 1) - 0.12951760) < 1e-7
=> true
load("packages/dist.nu"); abs(student.cdf(2.0, 10) - 0.96330598) < 1e-7
=> true
load("packages/dist.nu"); abs(student.inv(0.975, 30) - 2.0422725) < 1e-6
=> true
load("packages/dist.nu"); abs(student.inv(0.999, 1) - 318.30884) < 1e-3
=> true
load("packages/dist.nu"); abs(chi2.cdf(7.81, 3) - 0.94989394) < 1e-7
=> true
load("packages/dist.nu"); abs(chi2.inv(0.95, 3) - 7.8147279) < 1e-6
=> true
load("packages/dist.nu"); abs(fdist.cdf(3.0, 4, 20) - 0.95679900) < 1e-7
=> true
load("packages/dist.nu"); abs(fdist.inv(0.95, 4, 20) - 2.8660814) < 1e-6
=> true
load("packages/dist.nu"); abs(expo.inv(0.5, 2) - 0.34657359) < 1e-7
=> true
# identities: inv inverts cdf; symmetry; densities integrate to cdf differences
load("packages/dist.nu"); abs(student.cdf(student.inv(0.85, 12), 12) - 0.85) < 1e-9
=> true
load("packages/dist.nu"); abs(student.cdf(-1.3, 9) + student.cdf(1.3, 9) - 1) < 1e-12
=> true
load("packages/dist.nu"); abs(integral(fn x -> norm.pdf(x, 0, 1), -1.96, 1.96) - (norm.cdf(1.96, 0, 1) - norm.cdf(-1.96, 0, 1))) < 1e-8
=> true
load("packages/dist.nu"); abs(integral(fn x -> chi2.pdf(x, 4), 0, 3) - chi2.cdf(3, 4)) < 1e-8
=> true
# sampling: reproducible, right moments
load("packages/dist.nu"); rng(7); let z = norm.rand(5000, 0, 1); (abs(mean(z)) < 0.05) && (abs(std(z) - 1) < 0.05)
=> true
