# if-expression, for, while, pipe
if true then 1 else 2 end
=> 1
if false then 1 else 2 end
=> 2
if 2 > 3 then 10 else 20 end
=> 20
if true then if false then 1 else 2 end else 3 end
=> 2
let s = 0; for i = 1:10 do s = s + i end; s
=> 55
let p = 1; for i = 1:5 do p = p * i end; p
=> 120
let s = 0; for x = [10, 20, 30] do s = s + x end; s
=> 60
let n = 5; let f = 1; while n > 0 do f = f * n; n = n - 1 end; f
=> 120
let i = 0; while i < 100 do i = i + 1 end; i
=> 100
9 |> sqrt(@)
=> 3
[1, 2, 3, 4] |> sum(@)
=> 10
16 |> sqrt(@) |> sqrt(@)
=> 2
1:5 |> sum(@) |> sqrt(@)
=> 3.87298
# bare-callable pipe: x |> f applies f to x (README documents this)
9 |> sqrt
=> 3
16 |> sqrt |> sqrt
=> 2
5 |> (_ + 1)
=> 6
let inc = fn x -> x + 1; 10 |> inc
=> 11
[1, 2, 3, 4] |> map((_ * 10), @) |> sum(@)
=> 100
