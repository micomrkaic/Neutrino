# Indexed assignment with copy-on-write
let a = [1, 2, 3, 4, 5]; a[2] = 99; a
=> [1, 99, 3, 4, 5]
let m = [1, 2; 3, 4]; m[1, 2] = 88; m
=> [1, 88; 3, 4]
let a = [1, 2, 3, 4, 5]; a[2:4] = [20, 30, 40]; a
=> [1, 20, 30, 40, 5]
let a = [1, 2, 3, 4, 5]; a[2:4] = 0; a
=> [1, 0, 0, 0, 5]
let a = [1, 2, 3, 4, 5]; a[[1, 3, 5]] = [10, 30, 50]; a
=> [10, 2, 30, 4, 50]
let a = [1, 2, 3, 4, 5]; a[a > 3] = 0; a
=> [1, 2, 3, 0, 0]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[2, :] = [40, 50, 60]; m
=> [1, 2, 3; 40, 50, 60; 7, 8, 9]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[:, 2] = 0; m
=> [1, 0, 3; 4, 0, 6; 7, 0, 9]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[1:2, 1:2] = [10, 20; 30, 40]; m
=> [10, 20, 3; 30, 40, 6; 7, 8, 9]
let a = [1, 2, 3, 4, 5]; a[end] = 100; a
=> [1, 2, 3, 4, 100]
let a = [1, 2, 3, 4, 5]; a[end-1:end] = [40, 50]; a
=> [1, 2, 3, 40, 50]
# copy-on-write: an aliased array is untouched
let a = [1, 2, 3]; let b = a; b[1] = 99; a
=> [1, 2, 3]
let a = [1, 2, 3]; let b = a; b[1] = 99; b
=> [99, 2, 3]
# element-type promotion on assignment
let a = [1, 2, 3]; a[2] = 2.5; a
=> [1, 2.5, 3]
# errors
let a = [1, 2, 3]; a[5] = 9
=> !out of bounds
let a = [1, 2, 3]; a[1:2] = [1, 2, 3]
=> !size mismatch
let a = [1, 2, 3]; a[1] = "x"
=> !cannot assign
let x = 5; x[1] = 9
=> !not indexable
