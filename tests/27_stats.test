# Descriptive statistics. Values cross-checked against NumPy.
var([2, 7, 4, 9, 3])
=> 8.5
var([2, 7, 4, 9, 3], 1)
=> 6.8
# population = sample * (n-1)/n
abs(var([1, 4, 6, 8], 1) - var([1, 4, 6, 8]) * 3 / 4) < 1e-15
=> true
format(8); std([2, 7, 4, 9, 3])
=> 2.9154759
# std^2 == var
abs(std([3, 1, 4, 1, 5]) ^ 2 - var([3, 1, 4, 1, 5])) < 1e-14
=> true
# var is translation invariant, scales quadratically
abs(var([1, 2, 3] + 100) - var([1, 2, 3])) < 1e-12
=> true
abs(var(3 * [1, 2, 5]) - 9 * var([1, 2, 5])) < 1e-13
=> true
median([2, 7, 4, 9, 3])
=> 4
median([1, 2, 3, 4])
=> 2.5
median([1, 2, 3; 4, 5, 6; 7, 8, 100], 1)
=> [4, 5, 6]
median([1, 2, 3; 4, 5, 6; 7, 8, 100], 2)
=> [2; 5; 8]
format(8); var([1, 2, 3; 4, 5, 6; 7, 8, 100], 0, 2)
=> [1.0000000; 1.0000000; 2852.3333]
quantile([2, 7, 4, 9, 3], 0.25)
=> 3
quantile([2, 7, 4, 9, 3], [0, 0.5, 0.9, 1])
=> [2, 4, 8.2, 9]
# quantile 0.5 == median
abs(quantile([3, 1, 4, 1, 5, 9], 0.5) - median([3, 1, 4, 1, 5, 9])) < 1e-15
=> true
# scalar and single-element behavior
var(5)
=> 0
median(7)
=> 7
std([4])
=> 0
# logicals count as 0/1 like sum
format(8); std([2, 7, 4, 9, 3] > 3)
=> 0.54772256
# errors
median([])
=> !empty data
var([1, 2], 2)
=> !normalization must be 0
quantile([1, 2, 3], 1.5)
=> !p must be in [0, 1]
std([1 + 2i, 3])
=> !complex data has no ordering
median([1, 2], 3)
=> !dim
# covariance / correlation. Cross-checked against NumPy.
format(8); cov([1, 2, 10; 2, 4, 9; 3, 6, 7; 4, 8, 2; 5, 10, 1])
=> [2.5000000, 5.0000000, -6.2500000; 5.0000000, 10.000000, -12.500000; -6.2500000, -12.500000, 16.700000]
cov([1, 2, 3, 4, 5], [2, 1, 4, 3, 5])
=> 2
cov([1, 2, 3, 4, 5], [2, 1, 4, 3, 5], 1)
=> 1.6
format(8); corr([1, 2, 3, 4, 5], [2, 1, 4, 3, 5])
=> 0.80000000
# diag of cov == per-column var
let X = [3, 1; 4, 1; 5, 9; 2, 6]; abs(sum(diag(cov(X)) - var(X, 0, 1)') ) < 1e-13
=> true
# corr(x, x) == 1; corr is scale/translation invariant
corr([2, 7, 1, 9], [2, 7, 1, 9])
=> 1
abs(corr([1, 5, 3], [2, 4, 9]) - corr(10 * [1, 5, 3] + 7, [2, 4, 9])) < 1e-14
=> true
# cov(x, y) symmetric; cov(x, x) == var(x)
abs(cov([1, 4, 2], [5, 3, 8]) - cov([5, 3, 8], [1, 4, 2])) < 1e-15
=> true
abs(cov([2, 7, 4, 9], [2, 7, 4, 9]) - var([2, 7, 4, 9])) < 1e-15
=> true
# a vector to cov/corr degrades to the scalar forms
abs(cov([3, 1, 4, 1, 5]) - var([3, 1, 4, 1, 5])) < 1e-15
=> true
corr([3, 1, 4])
=> 1
# constant column -> nan (0/0), sign-normalized display
corr([1, 2; 1, 3; 1, 4])
=> [nan, nan; nan, 1]
# errors
cov([1, 2], [1, 2, 3])
=> !vectors differ in length
corr(5)
=> !expected numeric data
cov([1, 2; 3, 4], 2)
=> !normalization must be 0
