# where clauses: definitions after use, desugared to let..in
a * 4 ^ 2 + b * 4 + c where a = 1, b = -3, c = 2
=> 6
# sequential: later bindings see earlier ones
x + y where x = 2, y = x * 10
=> 22
# ...and not vice versa (this is a let-chain, not Haskell's binding group)
sqrt(h) where h = hs + 1, hs = 3
=> !undefined name
sqrt(h) where hs = 3, h = hs + 1
=> 2
# scoped to the expression: nothing leaks
(z where z = 9); z
=> !undefined name
# shadows without damaging the outer binding
let a = 100; (a + b where a = 1, b = a + 1) == 3 && a == 100
=> true
# binds looser than pipes and chains
1:n ~> (@ ^ 2) |> sum where n = 5
=> 55
0 < z < w where z = 0.5, w = 1
=> true
# works inside a function body (lexical constants)
let f = fn x -> x * k where k = 3; f(2)
=> 6
# in a let statement's value
let y = m * 2 where m = 21; y
=> 42
# parse errors teach
5 where
=> !expected a name
5 where q
=> !expected '='
# the old builtin spellings, renamed
find([0, 5, 0, 7] > 1)
=> [2, 4]
pick([1, 0, 1] > 0, [9, 9, 9], [0, 0, 0])
=> [9, 0, 9]
# 'where' is a keyword now: the old call form is a parse error
where([1, 0])
=> !parse error
