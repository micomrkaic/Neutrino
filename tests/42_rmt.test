# rmt.nu: structured random matrices — property-based goldens (seeded)
load("packages/rmt.nu"); rng(7); let S = randsym(4); max(max(abs(S - S'))) == 0
=> true
load("packages/rmt.nu"); rng(7); let P = randspd(4); let L = chol(P); max(max(abs(L * L' - P))) < 1e-9
=> true
load("packages/rmt.nu"); rng(7); let W = wishart(4); min(eig(W).values > 0)
=> true
load("packages/rmt.nu"); rng(7); let Q = randorth(4); max(max(abs(Q' * Q - eye(4)))) < 1e-12
=> true
load("packages/rmt.nu"); rng(7); sort(randperm(6)) == 1:6
=> [true, true, true, true, true, true]
load("packages/rmt.nu"); rng(3); let M = permmat(randperm(4)); sum(sum(M)) == 4
=> true
load("packages/rmt.nu"); rng(7); let C = randcorr(4); max(abs(diag(C) - 1)) < 1e-12
=> true
load("packages/rmt.nu"); rng(7); let T = randstoch(5); max(abs(sum(T, 2) - 1)) < 1e-12
=> true
load("packages/rmt.nu"); rng(7); let H = goe(200); max(abs(eig(H).values)) < 2.4
=> true
load("packages/rmt.nu"); rng(7); let H = goe(50); max(max(abs(H - H'))) == 0
=> true
