# Index-read generalization: ranges, gather, colon, submatrices
# (result shape: gather follows the index shape; a[:] is a column; mask follows the target)
let a = [10, 20, 30, 40, 50]; a[3]
=> 30
let a = [10, 20, 30, 40, 50]; a[2:4]
=> [20, 30, 40]
let a = [10, 20, 30, 40, 50]; a[[1, 3, 5]]
=> [10, 30, 50]
let a = [10, 20, 30, 40, 50]; a[[2; 4]]
=> [20; 40]
let a = [10, 20, 30, 40, 50]; a[:]
=> [10; 20; 30; 40; 50]
let a = [10, 20, 30, 40, 50]; a[a > 25]
=> [30, 40, 50]
let a = 1:10; a[a > 5][1]
=> 6
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[2, 3]
=> 6
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[2, :]
=> [4, 5, 6]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[:, 2]
=> [2; 5; 8]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[1:2, 1:2]
=> [1, 2; 4, 5]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[[1, 3], [1, 3]]
=> [1, 3; 7, 9]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[:, :]
=> [1, 2, 3; 4, 5, 6; 7, 8, 9]
let m = [1, 2, 3; 4, 5, 6]; m[:, [1, 3]]
=> [1, 3; 4, 6]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; sum(m[2, :])
=> 15
let m = [1, 2; 3, 4]; trace(m[:, :])
=> 5
let a = [1, 2, 3]; a[2:5]
=> !out of bounds
let a = [1, 2, 3]; a[[1, 9]]
=> !out of bounds
let m = [1, 2; 3, 4]; m[3, :]
=> !out of bounds
let a = [1, 2, 3]; a[[1.5, 2.5]]
=> !index array must be Int
# 'end' inside an index resolves to the current dimension's size
let a = [10, 20, 30, 40, 50]; a[end]
=> 50
let a = [10, 20, 30, 40, 50]; a[end-1]
=> 40
let a = [10, 20, 30, 40, 50]; a[2:end]
=> [20, 30, 40, 50]
let a = [10, 20, 30, 40, 50]; a[1:2:end]
=> [10, 30, 50]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[end, :]
=> [7, 8, 9]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[:, end]
=> [3; 6; 9]
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[end, end]
=> 9
let m = [1, 2, 3; 4, 5, 6; 7, 8, 9]; m[end-1, 2:end]
=> [5, 6]
let a = [10, 20, 30]; let b = [1, 2, 3, 4, 5, 6]; a[b[end] - 3]
=> 30
let m = [1, 2; 3, 4]; m[end+1, 1]
=> !out of bounds
