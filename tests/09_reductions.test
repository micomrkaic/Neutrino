# Reductions and logical aggregates
sum([1, 2, 3, 4, 5])
=> 15
sum(1:100)
=> 5050
min([3, 1, 4, 1, 5])
=> 1
max([3, 1, 4, 1, 5])
=> 5
mean([2, 4, 6])
=> 4
prod([1, 2, 3, 4])
=> 24
any([false, false, true])
=> true
any([false, false])
=> false
all([true, true, true])
=> true
all([true, false])
=> false
sum([1, 2, 3] > 1)
=> 2
sum([true, true, false])
=> 2
